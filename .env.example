# Meta WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Persistent storage (Supabase Postgres - free tier).
# Required for conversations to survive serverless cold starts AND for the
# admin inbox. Create a free project at https://supabase.com (or via the Vercel
# Marketplace), run supabase-schema.sql, then provide:
#   - the project URL  (SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL both work)
#   - the service_role key (server-side only — never expose it publicly)
# The Vercel/Supabase integration adds these automatically; the code reads
# either SUPABASE_URL/NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin inbox (/admin) password - choose any strong password.
ADMIN_PASSWORD=choose_a_strong_password

# Next.js
NEXT_PUBLIC_WHATSAPP_NUMBER=966581008879
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Bank Transfer Details (shown to customers)
NEXT_PUBLIC_BANK_NAME=البنك الأهلي السعودي
NEXT_PUBLIC_IBAN=SA0000000000000000000000
NEXT_PUBLIC_ACCOUNT_NAME=اسم صاحب الحساب
